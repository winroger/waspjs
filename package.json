{
  "name": "webwaspjs",
  "version": "0.3.1",
  "type": "module",
  "description": "JavaScript port of WASP for discrete aggregations (Three.js)",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest --run",
    "test:watch": "vitest watch",
    "lint": "eslint \"src/**/*.js\"",
    "format": "prettier -w ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/winroger/waspjs.git"
  },
  "keywords": [
    "wasp",
    "aggregation",
    "threejs",
    "discrete",
    "geometry"
  ],
  "author": "Roger Winkler",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "dependencies": {
    "camera-controls": "^2.9.0",
    "three-mesh-bvh": "^0.8.2"
  },
  "peerDependencies": {
    "three": "^0.169.0"
  },
  "devDependencies": {
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.2.5",
    "three": "^0.169.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  },
  "directories": {
    "test": "src/tests"
  },
  "bugs": {
    "url": "https://github.com/winroger/waspjs/issues"
  },
  "homepage": "https://github.com/winroger/waspjs#readme"
}
